  "keyFeatures": [
    "Fully autonomous pentesting with zero intervention",
    "Multi-phase AI agent workflow (reconnaissance, vulnerability analysis, exploitation, reporting)",
    "Advanced 2FA/TOTP and SSO authentication support",
    "Parallel vulnerability processing for faster results",
    "Durable workflow orchestration with crash recovery via Temporal",
    "Code-aware dynamic testing combining white-box and black-box analysis",
    "Reproducible exploits with proof-of-concept code",
    "Integration with security tools (Nmap, Subfinder, WhatWeb, Schemathesis)",
    "Workspace management and resume capability",
    "Multi-provider AI support (Anthropic, AWS Bedrock, Google Vertex AI)"
  ],
  "publicApiSurface": [
    "./shannon start - Start pentest workflow",
    "./shannon workspaces - List all workspaces",
    "./shannon logs - View real-time worker logs",
    "./shannon query - Query workflow progress",
    "./shannon stop - Stop containers",
    "AGENTS registry - Pre-recon, Recon, Injection, XSS, Auth, Authz, SSRF vulnerability and exploit agents",
    "pentestPipelineWorkflow - Main Temporal workflow orchestrator",
    "Config YAML - Authentication, retry strategies, pipeline settings",
    "MCP servers - shannon-helper, playwright-agent1-5",
    "Claude Agent SDK integration - AI execution engine"
  ]
